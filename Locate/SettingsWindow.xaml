<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Locate.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Locate.ViewModels"
    xmlns:models="using:Locate.Models"
    xmlns:local="using:Locate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Locate — Settings">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="14" RowSpacing="10">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapePressed" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />

        <!-- External editor -->
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="External editor" FontWeight="SemiBold" FontSize="12" />
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{x:Bind ViewModel.EditorCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText='&quot;C:\...\code.exe&quot; --goto &quot;%path%&quot;:%line%:%column%' FontSize="12" />
                <Button Grid.Column="1" Content="Browse…" Click="OnBrowseEditorClicked" />
            </Grid>
            <TextBlock Opacity="0.7" FontSize="11"
                       Text="Placeholders: %path%, %line%, %column%. Quote %path% if it may contain spaces." />
            <CheckBox Content="Don't warn when replacing (Replace button replaces immediately, no .bak; Ctrl+Alt+Enter behaves the same regardless)"
                      IsChecked="{x:Bind ViewModel.DontWarnWhenReplacing, Mode=TwoWay}" Margin="0,4,0,0" />
            <CheckBox Content="Remember recently used values between sessions"
                      IsChecked="{x:Bind ViewModel.RememberRecentValues, Mode=TwoWay}" />
        </StackPanel>

        <!-- Presets -->
        <Grid Grid.Row="2" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Add/Remove sit next to the Presets title, mirroring the WHAT/FILTER Reset pattern
                 on the main window — keeps related actions in one place rather than at opposite
                 ends of a wide row. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Presets" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                <Button Style="{StaticResource SmallButton}" Command="{x:Bind ViewModel.AddPresetCommand}"
                        ToolTipService.ToolTip="Add a new preset">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE710;" FontSize="10" />
                        <TextBlock Text="Add" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SmallButton}" Command="{x:Bind ViewModel.RemovePresetCommand}"
                        ToolTipService.ToolTip="Remove the selected preset">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE738;" FontSize="10" />
                        <TextBlock Text="Remove" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <ListView x:Name="PresetList"
                              ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Preset">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontSize="12" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                    <StackPanel Spacing="10"
                                DataContext="{x:Bind ViewModel.SelectedPreset, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.HasSelectedPreset, Mode=OneWay}">
                        <TextBlock Text="Preset details" FontWeight="SemiBold" FontSize="12" />

                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Name:" Grid.Row="0" VerticalAlignment="Top" Margin="0,6,0,0" FontSize="12" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"
                                         BorderBrush="{x:Bind ViewModel.SelectedPresetNameBorderBrush, Mode=OneWay}"
                                         BorderThickness="2" />
                                <!-- Empty-name / duplicate-name feedback. -->
                                <TextBlock Text="{x:Bind ViewModel.SelectedPresetNameError, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.SelectedPresetNameErrorVisibility, Mode=OneWay}"
                                           Foreground="IndianRed" FontSize="11" />
                            </StackPanel>

                            <TextBlock Text="Hotkey:" Grid.Row="1" VerticalAlignment="Top" Margin="0,6,0,0" FontSize="12" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                <Grid>
                                    <!-- TextBox + overlapping "Assign" button on the right edge. The
                                         right-padding on the TextBox keeps typed text from running
                                         under the button. -->
                                    <TextBox x:Name="HotkeyBox"
                                             Text="{Binding Hotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="e.g. Ctrl+1, Alt+F2 — leave empty for none" FontSize="12"
                                             Padding="10,5,72,5"
                                             BorderBrush="{x:Bind ViewModel.SelectedPresetHotkeyBorderBrush, Mode=OneWay}"
                                             BorderThickness="2" />
                                    <Button Style="{StaticResource SmallButton}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Margin="0,0,4,0"
                                            Click="OnAssignHotkeyClicked"
                                            ToolTipService.ToolTip="Press a hotkey to capture it">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE765;" FontSize="10" />
                                            <TextBlock Text="Assign" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <!-- Reserved / parse-error / duplicate feedback. Empty hotkey is fine. -->
                                <TextBlock Text="{x:Bind ViewModel.SelectedPresetHotkeyError, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.SelectedPresetHotkeyErrorVisibility, Mode=OneWay}"
                                           Foreground="IndianRed" FontSize="11" />
                            </StackPanel>

                            <TextBlock Text="Apply groups:" Grid.Row="2" VerticalAlignment="Top" Margin="0,4,0,0" FontSize="12" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                <CheckBox Style="{StaticResource CompactCheckBox}"
                                          Content="Where  —  search-in directories"
                                          IsChecked="{Binding ApplyWhere, Mode=TwoWay}" />
                                <CheckBox Style="{StaticResource CompactCheckBox}"
                                          Content="What  —  search / replace patterns and matching toggles"
                                          IsChecked="{Binding ApplyWhat, Mode=TwoWay}" />
                                <CheckBox Style="{StaticResource CompactCheckBox}"
                                          Content="Filter  —  file names, exclude paths, size / date, traversal"
                                          IsChecked="{Binding ApplyFilter, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,4,0,0" Opacity="0.6" FontSize="11" TextWrapping="Wrap"
                                   Text="When activated, only checked groups are filled. Unchecked groups are left untouched. To re-snapshot the captured form values, save a new preset from the main window." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3">
            <Button Content="Reset everything…" Click="OnResetEverythingClicked" HorizontalAlignment="Left"
                    ToolTipService.ToolTip="Erase all settings, presets, and recent values" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                <Button Content="Save" Click="OnSaveClicked" Style="{ThemeResource AccentButtonStyle}" />
                <Button Content="Close" Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
