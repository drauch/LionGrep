<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Locate.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Locate.ViewModels"
    xmlns:models="using:Locate.Models"
    xmlns:local="using:Locate"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Locate — Settings">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="14" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" />

        <!-- External editor -->
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="External editor" FontWeight="SemiBold" FontSize="12" />
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{x:Bind ViewModel.EditorCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText='&quot;C:\...\code.exe&quot; --goto &quot;%path%&quot;:%line%:%column%' FontSize="12" />
                <Button Grid.Column="1" Content="Browse…" Click="OnBrowseEditorClicked" />
            </Grid>
            <TextBlock Opacity="0.7" FontSize="11"
                       Text="Placeholders: %path%, %line%, %column%. Quote %path% if it may contain spaces." />
            <CheckBox Content="Remember recently used values between sessions"
                      IsChecked="{x:Bind ViewModel.RememberRecentValues, Mode=TwoWay}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Presets -->
        <Grid Grid.Row="2" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="Presets" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                    <Button Content="Add" Command="{x:Bind ViewModel.AddPresetCommand}" />
                    <Button Content="Remove" Command="{x:Bind ViewModel.RemovePresetCommand}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <ListView x:Name="PresetList"
                              ItemsSource="{x:Bind ViewModel.Presets, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedPreset, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Preset">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontSize="12" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="6"
                                    DataContext="{x:Bind ViewModel.SelectedPreset, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.HasSelectedPreset, Mode=OneWay}">
                            <TextBlock Text="Preset details" FontWeight="SemiBold" FontSize="12" />
                            <Grid ColumnSpacing="8" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Name:" Grid.Row="0" VerticalAlignment="Center" FontSize="12" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" />

                                <TextBlock Text="Hotkey:" Grid.Row="1" VerticalAlignment="Center" FontSize="12" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Hotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="e.g. Ctrl+1" FontSize="12" />

                                <TextBlock Text="Apply groups:" Grid.Row="2" VerticalAlignment="Top" Margin="0,4,0,0" FontSize="12" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="3">
                                    <CheckBox Content="Where (search-in directories)" IsChecked="{Binding ApplyWhere, Mode=TwoWay}" />
                                    <CheckBox Content="What (search/replace + matching toggles)" IsChecked="{Binding ApplyWhat, Mode=TwoWay}" />
                                    <CheckBox Content="Filter (file names, exclude dirs, size/date, traversal)" IsChecked="{Binding ApplyFilter, Mode=TwoWay}" />
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Margin="0,6,0,0"
                                           Opacity="0.6" FontSize="11"
                                           Text="When activated, only checked groups are filled. Unchecked groups are left untouched. To re-snapshot the captured form values, save a new preset from the main window." />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3">
            <Button Content="Reset everything…" Click="OnResetEverythingClicked" HorizontalAlignment="Left"
                    ToolTipService.ToolTip="Erase all settings, presets, and recent values" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                <Button Content="Save" Click="OnSaveClicked" Style="{ThemeResource AccentButtonStyle}" />
                <Button Content="Close" Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
