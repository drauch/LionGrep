<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Locate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Locate.ViewModels"
    xmlns:models="using:Locate.Models"
    xmlns:lc="using:Locate.Controls"
    xmlns:local="using:Locate"
    Title="Locate">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OnCtrlEnterAccelerator" />
            <KeyboardAccelerator Key="Enter" Modifiers="Control,Menu" Invoked="OnCtrlAltEnterAccelerator" />
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition x:Name="FormRow" Height="2*" MinHeight="0" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <x:Double x:Key="CheckBoxBackgroundSize">14</x:Double>
            <x:Double x:Key="CheckBoxCheckGlyphSize">12</x:Double>

            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="Margin" Value="0,4,0,2" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="CompactCheckBox" TargetType="CheckBox">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="6,0,0,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="NormalRectangle"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Width="13" Height="13"
                                        VerticalAlignment="Center" />
                                <FontIcon x:Name="CheckGlyph" Grid.Column="0"
                                          Glyph="&#xE73E;" FontSize="9"
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center" />
                                <ContentPresenter Grid.Column="1"
                                                  Content="{TemplateBinding Content}"
                                                  Margin="{TemplateBinding Padding}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  VerticalAlignment="Center" />
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="NormalRectangle.BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Opacity" Value="0.4" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="NormalRectangle.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <Setter Target="NormalRectangle.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <Setter Target="CheckGlyph.Visibility" Value="Visible" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Indeterminate">
                                            <VisualState.Setters>
                                                <Setter Target="NormalRectangle.Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <Setter Target="NormalRectangle.BorderBrush" Value="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="ToolIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
            </Style>
            <Style x:Key="RecentsButton" TargetType="Button">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="VerticalAlignment" Value="Top" />
            </Style>
            <Style x:Key="SmallButton" TargetType="Button">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
            </Style>
            <Style x:Key="ColumnResizer" TargetType="lc:ColumnResizer">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Width" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
            </Style>
        </Grid.Resources>

        <!-- Title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="148" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.WindowTitle, Mode=OneWay}" FontSize="12"
                       Margin="12,0,0,0" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="0,2,4,2">
                <Button Style="{StaticResource ToolIconButton}" ToolTipService.ToolTip="Settings" Click="OnSettingsClicked">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource ToolIconButton}" ToolTipService.ToolTip="About" Click="OnAboutClicked">
                    <FontIcon Glyph="&#xE897;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Form area: content scroll + bottom-right action bar -->
        <Grid Grid.Row="1" x:Name="FormAreaGrid" SizeChanged="OnFormAreaSizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="6,2,6,2">
                <StackPanel x:Name="FormStackPanel" Spacing="2" Loaded="OnFormStackPanelLoaded">

                    <!-- WHERE -->
                    <TextBlock Text="WHERE" Style="{StaticResource SectionHeader}" />
                    <Grid ColumnSpacing="6" RowSpacing="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Search in:" Style="{StaticResource FieldLabel}" VerticalAlignment="Top" Margin="0,4,0,0" />
                        <TextBox x:Name="SearchInBox" Grid.Column="1"
                                 Text="{x:Bind ViewModel.SearchIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 PlaceholderText="One directory per line, or click Browse"
                                 Height="{x:Bind ViewModel.SearchInBoxHeight, Mode=OneWay}"
                                 FontSize="12" />
                        <ToggleButton Grid.Column="2" VerticalAlignment="Top"
                                      IsChecked="{x:Bind ViewModel.IsSearchInExpanded, Mode=TwoWay}"
                                      Padding="6,4" MinWidth="0" MinHeight="32"
                                      ToolTipService.ToolTip="Expand / collapse">
                            <FontIcon Glyph="&#xE740;" FontSize="10" />
                        </ToggleButton>
                        <Button Grid.Column="3" VerticalAlignment="Top"
                                Style="{StaticResource RecentsButton}" Click="OnSearchInRecentsClicked"
                                ToolTipService.ToolTip="Recent">
                            <FontIcon Glyph="&#xE823;" FontSize="12" />
                        </Button>
                        <Button Grid.Column="4" VerticalAlignment="Top" Content="Browse…" Click="OnBrowseClicked" />
                    </Grid>

                    <!-- WHAT (with Reset button) -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="WHAT" Style="{StaticResource SectionHeader}" />
                        <Button Style="{StaticResource SmallButton}"
                                Command="{x:Bind ViewModel.ResetWhatCommand}"
                                ToolTipService.ToolTip="Reset 'what' fields to defaults"
                                Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE777;" FontSize="10" />
                                <TextBlock Text="Reset" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Grid ColumnSpacing="6" RowSpacing="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Search for:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                        <TextBox x:Name="SearchPatternBox" Grid.Row="0" Grid.Column="1"
                                 Text="{x:Bind ViewModel.SearchPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Pattern (text or regex)"
                                 FontSize="12" />
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnSearchPatternRecentsClicked">
                            <FontIcon Glyph="&#xE823;" FontSize="12" />
                        </Button>

                        <TextBlock Text="Replace with:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                        <TextBox x:Name="ReplacePatternBox" Grid.Row="1" Grid.Column="1"
                                 Text="{x:Bind ViewModel.ReplacePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Replacement (literal or $1 backrefs)"
                                 FontSize="12" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnReplacePatternRecentsClicked">
                            <FontIcon Glyph="&#xE823;" FontSize="12" />
                        </Button>

                        <controls:WrapPanel Grid.Row="2" Grid.ColumnSpan="3" HorizontalSpacing="10" VerticalSpacing="2" Margin="0,1,0,0">
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Use regex" IsChecked="{x:Bind ViewModel.UseRegex, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Case sensitive" IsChecked="{x:Bind ViewModel.CaseSensitive, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Whole word" IsChecked="{x:Bind ViewModel.WholeWord, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Preserve case" IsChecked="{x:Bind ViewModel.PreserveCase, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Dot matches newline"
                                      IsChecked="{x:Bind ViewModel.DotMatchesNewline, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.IsDotMatchesNewlineEnabled, Mode=OneWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Search in file &amp; sub directory names"
                                      IsChecked="{x:Bind ViewModel.SearchInNames, Mode=TwoWay}" />
                            <CheckBox Style="{StaticResource CompactCheckBox}" Content="Keep file date when replacing"
                                      IsChecked="{x:Bind ViewModel.KeepFileDate, Mode=TwoWay}" />
                        </controls:WrapPanel>
                    </Grid>

                    <!-- FILTER (with Reset button) -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="FILTER" Style="{StaticResource SectionHeader}" />
                        <Button Style="{StaticResource SmallButton}"
                                Command="{x:Bind ViewModel.ResetFiltersCommand}"
                                ToolTipService.ToolTip="Reset filter values to defaults"
                                Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE777;" FontSize="10" />
                                <TextBlock Text="Reset" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Grid x:Name="FilterGrid" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="FilterLeftCol" Width="*" />
                            <ColumnDefinition x:Name="FilterRightCol" Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Column="0" Grid.RowSpan="2" ColumnSpacing="6" RowSpacing="3" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="File names:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                            <TextBox x:Name="FileNamesBox" Grid.Row="0" Grid.Column="1"
                                     Text="{x:Bind ViewModel.FileNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="*.cs|*.ts|!*.Generated.cs"
                                     FontSize="12" />
                            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnFileNamesRecentsClicked">
                                <FontIcon Glyph="&#xE823;" FontSize="12" />
                            </Button>
                            <CheckBox Grid.Row="0" Grid.Column="3" Style="{StaticResource CompactCheckBox}" Content="Regex"
                                      IsChecked="{x:Bind ViewModel.FileNamesRegex, Mode=TwoWay}" VerticalAlignment="Center" />

                            <TextBlock Text="Exclude paths:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                            <TextBox x:Name="ExcludePathsBox" Grid.Row="1" Grid.Column="1"
                                     Text="{x:Bind ViewModel.ExcludePaths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="bin|obj|node_modules|*.tmp"
                                     FontSize="12" />
                            <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnExcludePathsRecentsClicked">
                                <FontIcon Glyph="&#xE823;" FontSize="12" />
                            </Button>
                            <CheckBox Grid.Row="1" Grid.Column="3" Style="{StaticResource CompactCheckBox}" Content="Regex"
                                      IsChecked="{x:Bind ViewModel.ExcludePathsRegex, Mode=TwoWay}" VerticalAlignment="Center" />
                        </Grid>

                        <Grid x:Name="SizeDateGrid" Grid.Column="1" Grid.RowSpan="2" ColumnSpacing="6" RowSpacing="3" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Size:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                            <controls:WrapPanel Grid.Row="0" Grid.Column="1" HorizontalSpacing="4" VerticalSpacing="2">
                                <ComboBox SelectedIndex="{x:Bind ViewModel.SizeModeIndex, Mode=TwoWay}" MinWidth="110" FontSize="12">
                                    <ComboBoxItem Content="All sizes" />
                                    <ComboBoxItem Content="Less than" />
                                    <ComboBoxItem Content="Greater than" />
                                    <ComboBoxItem Content="Between" />
                                </ComboBox>
                                <NumberBox Value="{x:Bind ViewModel.SizeKb, Mode=TwoWay}"
                                           Minimum="0" SpinButtonPlacementMode="Hidden" Width="90"
                                           Loaded="OnSizeNumberBoxLoaded"
                                           Visibility="{x:Bind ViewModel.SizeValueVisibility, Mode=OneWay}" />
                                <TextBlock Text="and" Style="{StaticResource FieldLabel}"
                                           Visibility="{x:Bind ViewModel.SizeUpperVisibility, Mode=OneWay}" />
                                <NumberBox Value="{x:Bind ViewModel.SizeKbUpper, Mode=TwoWay}"
                                           Minimum="0" SpinButtonPlacementMode="Hidden" Width="90"
                                           Loaded="OnSizeNumberBoxLoaded"
                                           Visibility="{x:Bind ViewModel.SizeUpperVisibility, Mode=OneWay}" />
                                <TextBlock Text="KB" Style="{StaticResource FieldLabel}"
                                           Visibility="{x:Bind ViewModel.SizeValueVisibility, Mode=OneWay}" />
                            </controls:WrapPanel>

                            <TextBlock Text="Date:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                            <controls:WrapPanel Grid.Row="1" Grid.Column="1" HorizontalSpacing="4" VerticalSpacing="2">
                                <ComboBox SelectedIndex="{x:Bind ViewModel.DateModeIndex, Mode=TwoWay}" MinWidth="110" FontSize="12">
                                    <ComboBoxItem Content="All dates" />
                                    <ComboBoxItem Content="Newer than" />
                                    <ComboBoxItem Content="Older than" />
                                    <ComboBoxItem Content="Exactly on" />
                                    <ComboBoxItem Content="Between" />
                                </ComboBox>
                                <CalendarDatePicker Date="{x:Bind ViewModel.DateFrom, Mode=TwoWay}"
                                                    Visibility="{x:Bind ViewModel.DateFromVisibility, Mode=OneWay}"
                                                    DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                                    PlaceholderText="yyyy-mm-dd" />
                                <CalendarDatePicker Date="{x:Bind ViewModel.DateTo, Mode=TwoWay}"
                                                    Visibility="{x:Bind ViewModel.DateToVisibility, Mode=OneWay}"
                                                    DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                                    PlaceholderText="yyyy-mm-dd" />
                            </controls:WrapPanel>
                        </Grid>
                    </Grid>

                    <controls:WrapPanel HorizontalSpacing="10" VerticalSpacing="2" Margin="0,2,0,0">
                        <CheckBox Style="{StaticResource CompactCheckBox}" Content="Include subfolders" IsChecked="{x:Bind ViewModel.IncludeSubfolders, Mode=TwoWay}" />
                        <CheckBox Style="{StaticResource CompactCheckBox}" Content="Include system files" IsChecked="{x:Bind ViewModel.IncludeSystem, Mode=TwoWay}" />
                        <CheckBox Style="{StaticResource CompactCheckBox}" Content="Include hidden items" IsChecked="{x:Bind ViewModel.IncludeHidden, Mode=TwoWay}" />
                        <CheckBox Style="{StaticResource CompactCheckBox}" Content="Follow symbolic links" IsChecked="{x:Bind ViewModel.FollowSymlinks, Mode=TwoWay}" />
                        <CheckBox Style="{StaticResource CompactCheckBox}" Content="Skip binary files" IsChecked="{x:Bind ViewModel.SkipBinaryFiles, Mode=TwoWay}" />
                    </controls:WrapPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Action bar: bottom-right of form area -->
            <Grid Grid.Row="1" Padding="6,4,6,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                    <SplitButton x:Name="SearchSplit" Command="{x:Bind ViewModel.SearchCommand}"
                                 Visibility="{x:Bind ViewModel.SearchButtonVisibility, Mode=OneWay}">
                        <SplitButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE721;" FontSize="12" />
                                <TextBlock Text="Search" />
                            </StackPanel>
                        </SplitButton.Content>
                        <SplitButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Inverse search" Command="{x:Bind ViewModel.InverseSearchCommand}"
                                                ToolTipService.ToolTip="List files that do NOT match the pattern (binaries skipped)" />
                                <MenuFlyoutItem Text="Search in currently found files"
                                                Command="{x:Bind ViewModel.SearchInFoundFilesCommand}"
                                                ToolTipService.ToolTip="Re-run search using only the What inputs, restricted to the current result set (filters ignored)" />
                            </MenuFlyout>
                        </SplitButton.Flyout>
                    </SplitButton>
                    <Button Command="{x:Bind ViewModel.CancelSearchCommand}"
                            Visibility="{x:Bind ViewModel.CancelButtonVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE711;" FontSize="12" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnReplaceClicked"
                            IsEnabled="{x:Bind ViewModel.IsReplaceEnabled, Mode=OneWay}"
                            ToolTipService.ToolTip="Choose Replace, Replace with backups (.bak), or Cancel">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE74E;" FontSize="12" />
                            <TextBlock Text="Replace…" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.UndoReplaceCommand}"
                            ToolTipService.ToolTip="Undo the last Replace-with-backups by restoring the .bak files">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE7A7;" FontSize="12" />
                            <TextBlock Text="Undo" />
                        </StackPanel>
                    </Button>
                    <DropDownButton x:Name="PresetsButton">
                        <DropDownButton.Content>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE74C;" FontSize="12" />
                                <TextBlock Text="Presets" />
                            </StackPanel>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout x:Name="PresetsFlyout" Opening="OnPresetsFlyoutOpening" />
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <controls:GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                               ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" />

        <!-- Results: header + table share a single * row so the splitter has two star rows
             (Form 2* / Results *) to resize between. -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <!-- SEARCH RESULTS section header (title + buttons on the left, summary on the right) -->
        <Grid Grid.Row="0" Margin="8,4,8,2">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
            <TextBlock Text="SEARCH RESULTS" Style="{StaticResource SectionHeader}" />
            <Button x:Name="ShowQueryButton" Style="{StaticResource SmallButton}" Click="OnShowQueryClicked" Margin="0,4,0,0"
                    Visibility="Collapsed"
                    ToolTipService.ToolTip="Show search form (Esc)">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE70E;" FontSize="10" />
                    <TextBlock Text="Show query" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SmallButton}" Click="OnExpandAllClicked" Margin="0,4,0,0"
                    ToolTipService.ToolTip="Expand all">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE710;" FontSize="10" />
                    <TextBlock Text="Expand all" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SmallButton}" Click="OnCollapseAllClicked" Margin="0,4,0,0"
                    ToolTipService.ToolTip="Collapse all">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE738;" FontSize="10" />
                    <TextBlock Text="Collapse all" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SmallButton}" Click="OnExportToCsv" Margin="0,4,0,0"
                    ToolTipService.ToolTip="Save all results as a CSV file">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE74E;" FontSize="10" />
                    <TextBlock Text="Export to CSV" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SmallButton}" Click="OnOpenInExcel" Margin="0,4,0,0"
                    ToolTipService.ToolTip="Open all results in the default app for CSV (typically Excel)">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8A7;" FontSize="10" />
                    <TextBlock Text="Open in Excel" />
                </StackPanel>
            </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox x:Name="FilterBox"
                         Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Filter results…"
                         Width="200" Height="24" FontSize="12" MinHeight="0"
                         ToolTipService.ToolTip="Filter the results by file path or matched line text (debounced ~250ms)" />
                <TextBlock Text="{x:Bind ViewModel.FilterStatusText, Mode=OneWay}"
                           VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                <TextBlock Text="{x:Bind ViewModel.ResultsSummary, Mode=OneWay}"
                           VerticalAlignment="Center" Opacity="0.7" FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Margin="6,0,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{ThemeResource SubtleFillColorTertiaryBrush}" Padding="6,4,6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="{x:Bind ViewModel.NameWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.SizeWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.MatchesWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.PathWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.ExtWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.EncodingWidth, Mode=OneWay}" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="{x:Bind ViewModel.DateWidth, Mode=OneWay}" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="NameHeader" Grid.Column="1" Text="Name" FontWeight="SemiBold" FontSize="12"
                               Tag="Name" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="2" Style="{StaticResource ColumnResizer}" DragDelta="OnNameThumbDragDelta" />
                    <TextBlock x:Name="SizeHeader" Grid.Column="3" Text="Size" FontWeight="SemiBold" FontSize="12"
                               Tag="Size" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="4" Style="{StaticResource ColumnResizer}" DragDelta="OnSizeThumbDragDelta" />
                    <TextBlock x:Name="MatchesHeader" Grid.Column="5" Text="Matches" FontWeight="SemiBold" FontSize="12"
                               Tag="Matches" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="6" Style="{StaticResource ColumnResizer}" DragDelta="OnMatchesThumbDragDelta" />
                    <TextBlock x:Name="PathHeader" Grid.Column="7" Text="Path" FontWeight="SemiBold" FontSize="12"
                               Tag="Path" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="8" Style="{StaticResource ColumnResizer}" DragDelta="OnPathThumbDragDelta" />
                    <TextBlock x:Name="ExtHeader" Grid.Column="9" Text="Ext" FontWeight="SemiBold" FontSize="12"
                               Tag="Ext" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="10" Style="{StaticResource ColumnResizer}" DragDelta="OnExtThumbDragDelta" />
                    <TextBlock x:Name="EncodingHeader" Grid.Column="11" Text="Encoding" FontWeight="SemiBold" FontSize="12"
                               Tag="Encoding" Tapped="OnHeaderTapped" />
                    <lc:ColumnResizer Grid.Column="12" Style="{StaticResource ColumnResizer}" DragDelta="OnEncodingThumbDragDelta" />
                    <TextBlock x:Name="DateHeader" Grid.Column="13" Text="Date modified" FontWeight="SemiBold" FontSize="12"
                               Tag="Date" Tapped="OnHeaderTapped" />
                </Grid>

                <ListView x:Name="ResultsList" Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.FilteredResults, Mode=OneWay}"
                          SelectionMode="Extended">
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Open with editor" Click="OnOpenWithEditor">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Open with…" Click="OnOpenWithDialog" />
                            <MenuFlyoutItem Text="Open containing folder" Click="OnOpenContainingFolder">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE838;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Cut" Click="OnCutFiles">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C6;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Copy" Click="OnCopyFiles">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Copy path(s) to clipboard" Click="OnCopyFullPath" />
                            <MenuFlyoutItem Text="Copy filename(s) to clipboard" Click="OnCopyName" />
                            <MenuFlyoutItem Text="Copy line(s) to clipboard" Click="OnCopyLine" />
                            <MenuFlyoutItem Text="Copy as CSV" Click="OnCopyCsv" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Delete" Click="OnDeleteFiles">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Properties" Click="OnShowProperties">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE946;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FileMatchViewModel">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Padding="6,1,6,1"
                                      DoubleTapped="OnFileRowDoubleTapped"
                                      RightTapped="OnFileRowRightTapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="{x:Bind Parent.NameWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.SizeWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.MatchesWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.PathWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.ExtWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.EncodingWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="{x:Bind Parent.DateWidth, Mode=OneWay}" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0"
                                                  IsChecked="{x:Bind IsExpanded, Mode=TwoWay}"
                                                  Visibility="{x:Bind ChevronVisibility, Mode=OneTime}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Padding="2" MinWidth="0" Width="20" Height="20" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE70D;" FontSize="9" />
                                    </ToggleButton>
                                    <ItemsControl Grid.Column="1" ItemsSource="{x:Bind FileNameSegments}"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:FileNameSegment">
                                                <Grid>
                                                    <Border Background="#FFFFEB3B" Padding="0"
                                                            Visibility="{x:Bind MatchedVisibility, Mode=OneTime}">
                                                        <TextBlock Text="{x:Bind Text}" FontSize="12" Foreground="Black" />
                                                    </Border>
                                                    <TextBlock Text="{x:Bind Text}" FontSize="12"
                                                               Visibility="{x:Bind UnmatchedVisibility, Mode=OneTime}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Grid.Column="3" Text="{x:Bind SizeText}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="5" Text="{x:Bind MatchCountText}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="7" Text="{x:Bind Directory}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="9" Text="{x:Bind Extension}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                    <TextBlock Grid.Column="11" Text="{x:Bind EncodingName}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                    <TextBlock Grid.Column="13" Text="{x:Bind DateModifiedText}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                </Grid>

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind Lines}"
                                              Visibility="{x:Bind IsExpandedVisibility, Mode=OneWay}"
                                              Padding="28,0,8,2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LineMatchViewModel">
                                            <Grid Padding="0" DoubleTapped="OnLineDoubleTapped">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind PositionText}"
                                                           FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                           Foreground="Gray" Margin="0,0,8,0" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="{x:Bind PrefixText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                                                    <TextBlock Text="{x:Bind MatchText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind SuffixText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
