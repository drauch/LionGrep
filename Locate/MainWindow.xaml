<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Locate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Locate.ViewModels"
    xmlns:models="using:Locate.Models"
    xmlns:local="using:Locate"
    Title="Locate">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="6" RowSpacing="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="80" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style x:Key="SectionHeader" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Opacity" Value="0.7" />
                <Setter Property="Margin" Value="0,4,0,2" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            <Style x:Key="ToolIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
            </Style>
            <Style x:Key="RecentsButton" TargetType="Button">
                <Setter Property="Padding" Value="2,0" />
                <Setter Property="MinWidth" Value="22" />
                <Setter Property="Width" Value="22" />
            </Style>
        </Grid.Resources>

        <!-- Top action bar -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <SplitButton Command="{x:Bind ViewModel.SearchCommand}"
                             Visibility="{x:Bind ViewModel.SearchButtonVisibility, Mode=OneWay}">
                    <SplitButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE721;" FontSize="12" />
                            <TextBlock Text="Search" />
                        </StackPanel>
                    </SplitButton.Content>
                    <SplitButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Inverse search (TODO)" IsEnabled="False" />
                            <MenuFlyoutItem Text="Search in currently found files (TODO)" IsEnabled="False" />
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>
                <Button Command="{x:Bind ViewModel.CancelSearchCommand}"
                        Visibility="{x:Bind ViewModel.CancelButtonVisibility, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                        <TextBlock Text="Cancel" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ReplaceCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE74E;" FontSize="12" />
                        <TextBlock Text="Replace" />
                    </StackPanel>
                </Button>
                <DropDownButton x:Name="PresetsButton">
                    <DropDownButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE74C;" FontSize="12" />
                            <TextBlock Text="Presets" />
                        </StackPanel>
                    </DropDownButton.Content>
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="PresetsFlyout" Opening="OnPresetsFlyoutOpening" />
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button Content="Show query" Command="{x:Bind ViewModel.ShowFormCommand}"
                        Visibility="{x:Bind ViewModel.ShowFormButtonVisibility, Mode=OneWay}" Margin="6,0,0,0" />
                <TextBlock Text="{x:Bind ViewModel.ResultsSummary, Mode=OneWay}"
                           Opacity="0.7" VerticalAlignment="Center" FontSize="12" Margin="8,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="2">
                <ToggleButton x:Name="ExpandAllToggle" Content="Expand all" Click="OnExpandAllClicked" />
                <Button Style="{StaticResource ToolIconButton}" ToolTipService.ToolTip="Settings" Click="OnSettingsClicked">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource ToolIconButton}" ToolTipService.ToolTip="About" Click="OnAboutClicked">
                    <FontIcon Glyph="&#xE897;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Form (collapsible) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,2,0"
                      Visibility="{x:Bind ViewModel.FormVisibility, Mode=OneWay}">
            <StackPanel Spacing="2">

                <!-- WHERE -->
                <TextBlock Text="WHERE" Style="{StaticResource SectionHeader}" />
                <Grid ColumnSpacing="6" RowSpacing="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Search in:" Style="{StaticResource FieldLabel}" VerticalAlignment="Top" Margin="0,4,0,0" />
                    <TextBox x:Name="SearchInBox" Grid.Column="1"
                             Text="{x:Bind ViewModel.SearchIn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             PlaceholderText="One directory per line, or click Browse"
                             Height="{x:Bind ViewModel.SearchInBoxHeight, Mode=OneWay}"
                             FontSize="12" />
                    <ToggleButton Grid.Column="2" VerticalAlignment="Top"
                                  IsChecked="{x:Bind ViewModel.IsSearchInExpanded, Mode=TwoWay}"
                                  Padding="6" MinWidth="0"
                                  ToolTipService.ToolTip="Expand / collapse">
                        <FontIcon Glyph="&#xE70D;" FontSize="10" />
                    </ToggleButton>
                    <Button Grid.Column="3" VerticalAlignment="Top"
                            Style="{StaticResource RecentsButton}" Click="OnSearchInRecentsClicked"
                            ToolTipService.ToolTip="Recent">
                        <TextBlock Text="▾" FontSize="10" />
                    </Button>
                    <Button Grid.Column="4" VerticalAlignment="Top" Content="Browse…" Click="OnBrowseClicked" />
                </Grid>

                <!-- WHAT -->
                <TextBlock Text="WHAT" Style="{StaticResource SectionHeader}" />
                <Grid ColumnSpacing="6" RowSpacing="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Search for:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{x:Bind ViewModel.SearchPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Pattern (text or regex)" FontSize="12" />
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnSearchPatternRecentsClicked">
                        <TextBlock Text="▾" FontSize="10" />
                    </Button>

                    <TextBlock Text="Replace with:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{x:Bind ViewModel.ReplacePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="Replacement (literal or $1 backrefs)" FontSize="12" />
                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnReplacePatternRecentsClicked">
                        <TextBlock Text="▾" FontSize="10" />
                    </Button>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="10" Margin="0,1,0,0">
                        <CheckBox Content="Use regex" IsChecked="{x:Bind ViewModel.UseRegex, Mode=TwoWay}" />
                        <CheckBox Content="Case sensitive" IsChecked="{x:Bind ViewModel.CaseSensitive, Mode=TwoWay}" />
                        <CheckBox Content="Whole word" IsChecked="{x:Bind ViewModel.WholeWord, Mode=TwoWay}" />
                        <CheckBox Content="Preserve case" IsChecked="{x:Bind ViewModel.PreserveCase, Mode=TwoWay}" />
                        <CheckBox Content="Dot matches newline"
                                  IsChecked="{x:Bind ViewModel.DotMatchesNewline, Mode=TwoWay}"
                                  IsEnabled="{x:Bind ViewModel.IsDotMatchesNewlineEnabled, Mode=OneWay}" />
                        <CheckBox Content="Search in file &amp; sub directory names"
                                  IsChecked="{x:Bind ViewModel.SearchInNames, Mode=TwoWay}" />
                        <CheckBox Content="Keep file date when replacing"
                                  IsChecked="{x:Bind ViewModel.KeepFileDate, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>

                <!-- FILTER -->
                <TextBlock Text="FILTER" Style="{StaticResource SectionHeader}" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" ColumnSpacing="6" RowSpacing="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="File names:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{x:Bind ViewModel.FileNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="*.cs|*.ts|!*.Generated.cs" FontSize="12" />
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnFileNamesRecentsClicked">
                            <TextBlock Text="▾" FontSize="10" />
                        </Button>
                        <CheckBox Grid.Row="0" Grid.Column="3" Content="Regex"
                                  IsChecked="{x:Bind ViewModel.FileNamesRegex, Mode=TwoWay}" VerticalAlignment="Center" />

                        <TextBlock Text="Exclude paths:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{x:Bind ViewModel.ExcludePaths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="bin|obj|node_modules|*.tmp" FontSize="12" />
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource RecentsButton}" Click="OnExcludePathsRecentsClicked">
                            <TextBlock Text="▾" FontSize="10" />
                        </Button>
                        <CheckBox Grid.Row="1" Grid.Column="3" Content="Regex"
                                  IsChecked="{x:Bind ViewModel.ExcludePathsRegex, Mode=TwoWay}" VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Column="1" ColumnSpacing="6" RowSpacing="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Size:" Style="{StaticResource FieldLabel}" Grid.Row="0" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <ComboBox SelectedIndex="{x:Bind ViewModel.SizeModeIndex, Mode=TwoWay}" MinWidth="110" FontSize="12">
                                <ComboBoxItem Content="All sizes" />
                                <ComboBoxItem Content="Less than" />
                                <ComboBoxItem Content="Greater than" />
                            </ComboBox>
                            <NumberBox Value="{x:Bind ViewModel.SizeKb, Mode=TwoWay}"
                                       Minimum="0" SpinButtonPlacementMode="Compact" Width="90"
                                       IsEnabled="{x:Bind ViewModel.SizeValueEnabled, Mode=OneWay}" />
                            <TextBlock Text="KB" Style="{StaticResource FieldLabel}" />
                        </StackPanel>

                        <TextBlock Text="Date:" Style="{StaticResource FieldLabel}" Grid.Row="1" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <ComboBox SelectedIndex="{x:Bind ViewModel.DateModeIndex, Mode=TwoWay}" MinWidth="110" FontSize="12">
                                <ComboBoxItem Content="All dates" />
                                <ComboBoxItem Content="Newer than" />
                                <ComboBoxItem Content="Older than" />
                                <ComboBoxItem Content="Exactly on" />
                                <ComboBoxItem Content="Between" />
                            </ComboBox>
                            <CalendarDatePicker Date="{x:Bind ViewModel.DateFrom, Mode=TwoWay}"
                                                Visibility="{x:Bind ViewModel.DateFromVisibility, Mode=OneWay}"
                                                DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                                PlaceholderText="yyyy-mm-dd" />
                            <CalendarDatePicker Date="{x:Bind ViewModel.DateTo, Mode=TwoWay}"
                                                Visibility="{x:Bind ViewModel.DateToVisibility, Mode=OneWay}"
                                                DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                                PlaceholderText="yyyy-mm-dd" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
                    <CheckBox Content="Include subfolders" IsChecked="{x:Bind ViewModel.IncludeSubfolders, Mode=TwoWay}" />
                    <CheckBox Content="Include system files" IsChecked="{x:Bind ViewModel.IncludeSystem, Mode=TwoWay}" />
                    <CheckBox Content="Include hidden items" IsChecked="{x:Bind ViewModel.IncludeHidden, Mode=TwoWay}" />
                    <CheckBox Content="Follow symbolic links" IsChecked="{x:Bind ViewModel.FollowSymlinks, Mode=TwoWay}" />
                    <CheckBox Content="Skip binary files" IsChecked="{x:Bind ViewModel.SkipBinaryFiles, Mode=TwoWay}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <controls:GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch"
                               ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                               Visibility="{x:Bind ViewModel.FormVisibility, Mode=OneWay}" />

        <Border Grid.Row="3" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{ThemeResource SubtleFillColorTertiaryBrush}" Padding="6,4,6,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Name" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="3" Text="Matches" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="4" Text="Path" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="5" Text="Ext" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="6" Text="Encoding" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock Grid.Column="7" Text="Date modified" FontWeight="SemiBold" FontSize="12" />
                </Grid>

                <ListView x:Name="ResultsList" Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                          SelectionMode="Extended">
                    <ListView.KeyboardAccelerators>
                        <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAccelerator" />
                    </ListView.KeyboardAccelerators>
                    <ListView.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Copy name(s)" Click="OnCopyName" />
                            <MenuFlyoutItem Text="Copy full path(s)" Click="OnCopyFullPath" />
                            <MenuFlyoutItem Text="Copy line(s)" Click="OnCopyLine" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Copy as CSV  (Ctrl+C)" Click="OnCopyCsv" />
                        </MenuFlyout>
                    </ListView.ContextFlyout>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FileMatchViewModel">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Padding="6,1,6,1" DoubleTapped="OnFileRowDoubleTapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="240" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0"
                                                  IsChecked="{x:Bind IsExpanded, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Padding="2" MinWidth="0" Width="20" Height="20" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE70D;" FontSize="9" />
                                    </ToggleButton>
                                    <TextBlock Grid.Column="1" Text="{x:Bind FileName}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind SizeText}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind MatchCountText}" FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{x:Bind Directory}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="5" Text="{x:Bind Extension}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                    <TextBlock Grid.Column="6" Text="{x:Bind EncodingName}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                    <TextBlock Grid.Column="7" Text="{x:Bind DateModifiedText}" FontSize="12" VerticalAlignment="Center" Foreground="Gray" />
                                </Grid>

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind Lines}"
                                              Visibility="{x:Bind IsExpandedVisibility, Mode=OneWay}"
                                              Padding="28,0,8,2">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LineMatchViewModel">
                                            <Grid Padding="0" DoubleTapped="OnLineDoubleTapped">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{x:Bind PositionText}"
                                                           FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                           Foreground="Gray" Margin="0,0,8,0" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <TextBlock Text="{x:Bind PrefixText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                                                    <TextBlock Text="{x:Bind MatchText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind SuffixText}" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
